# =============================================================================
# Secrets & environment files
# =============================================================================
# Matches local.env, production.env, staging.env, etc.
# Does NOT match *.env.example — those are safe templates to commit.
*.env

# SSL / certificate files
**/*.pfx
**/*.p12


# =============================================================================
# .NET
# =============================================================================
**/bin/
**/obj/
**/publish/
**/TestResults/
**/*.coverage
**/*.coveragexml


# =============================================================================
# Node / Angular
# =============================================================================
**/node_modules/
**/dist/
**/.angular/
**/npm-debug.log*
**/yarn-error.log


# =============================================================================
# Docker
# =============================================================================
# Local overrides for docker-compose (port mappings, volume paths, etc.)
docker-compose.override.yml


# =============================================================================
# Visual Studio
# =============================================================================
.vs/
*.user
*.suo

# =============================================================================
# Rider
# =============================================================================
.idea/


# =============================================================================
# AI tooling
# =============================================================================
# Claude Code project memory — contains local context, not source code.
# Remove this line if you want to share AI context across the team.
.claude/


# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
